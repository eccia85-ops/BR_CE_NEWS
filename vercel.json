{
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" }
  ],
  "crons": [
    {
      "path": "/api/collect",
      "schedule": "0 22 * * *"
    }
  ],
  "routes": [
    { "src": "^/api/news$",     "dest": "/api/news.py" },
    { "src": "^/api/articles$", "dest": "/api/news.py" },
    { "src": "^/api/collect$",  "dest": "/api/news.py" },
    { "src": "^/api/brief$",    "dest": "/api/news.py" },
    { "src": "^/manage$",       "dest": "/api/manage.py" },
    { "src": "^/",          "dest": "/api/index.py" }
  ]
}
